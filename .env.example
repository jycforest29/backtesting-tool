# docker-compose 에서 읽는 환경변수 샘플.
# 실제 .env 파일에 값 채우고 git-ignore 유지.

# === 인증 / CORS ===
# 최소 하나의 *_API_KEY 를 설정하고 클라이언트가 X-API-Key 헤더로 전달.
# 운영 배포 시 반드시 SECURITY_FAIL_ON_MISSING_KEYS=true 로 설정.
SECURITY_FAIL_ON_MISSING_KEYS=false
ADMIN_API_KEY=
TRADER_API_KEY=
VIEWER_API_KEY=
SCRAPER_API_KEY=
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# === HTTP 레이트리밋 ===
HTTP_RATE_LIMIT_ENABLED=true

# === KIS OpenAPI ===
HANTOO_API_KEY=
HANTOO_API_SECRET=
HANTOO_ACCOUNT=
HANTOO_ACCOUNT_PRODUCT=01
HANTOO_PAPER_TRADING=false
HANTOO_RATE_PER_SEC=18

# === DART OpenAPI (계층 B 팩터 전략 + SPAC 이벤트) ===
DART_OPEN_API_KEY=

# === ELW 스큐 스캐너 ===
ELW_ENABLED=false
ELW_CHAIN_URL=
ELW_CHAIN_TR_ID=

# === Gmail 알림 (선택) ===
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
ALERT_RECIPIENT=

# === 안전장치 ===
DAILY_LOSS_LIMIT_KRW=100000

# === Redis ===
REDIS_PASSWORD=

# === Kafka (docker-compose 기본값 사용) ===
# KAFKA_BOOTSTRAP=kafka:9092

# === DB / Actuator ===
DB_PASSWORD=
H2_CONSOLE=false

# === 로그 ===
# SPRING_PROFILES_ACTIVE=prod  # → 구조화 JSON 로그
LOG_LEVEL_COM_BACKTESTING=INFO
