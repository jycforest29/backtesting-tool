# 참고용 샘플입니다. 이 파일은 쓰지 않고, 아래 값들을 OS 환경변수로 export 해서 쓰세요.
#
# ~/.bashrc 또는 ~/.zshrc 에 추가:
#   export HANTOO_API_KEY="PSxxxx..."
#   export HANTOO_API_SECRET="xxxx..."
#   export HANTOO_ACCOUNT="50123456"         # 계좌번호 앞 8자리
#   export HANTOO_ACCOUNT_PRODUCT="01"       # 보통 01 (위탁종합)
#   export HANTOO_PAPER_TRADING="true"       # true=모의투자, false=실전
#
# 적용: source ~/.bashrc (혹은 터미널 재시작)

HANTOO_API_KEY=
HANTOO_API_SECRET=
HANTOO_ACCOUNT=
HANTOO_ACCOUNT_PRODUCT=01
HANTOO_PAPER_TRADING=true

# DART OpenAPI (금감원 전자공시) — 팩터 전략(계층 B) + SPAC 이벤트 공시
# 발급: https://opendart.fss.or.kr/ (무료, 일 10,000건)
#   export DART_OPEN_API_KEY="40자리 키"
DART_OPEN_API_KEY=

# ELW 스큐 스캐너 (3번 전략)
# KIS ELW 엔드포인트/tr_id 는 KIS Developers 포털에서 확인 후 주입
# ELW_ENABLED=false 이면 /api/elw/skew 는 degraded 응답만 반환
ELW_ENABLED=false
ELW_CHAIN_URL=
ELW_CHAIN_TR_ID=
